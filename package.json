{
  "name": "adb-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for safely controlling Android emulators and physical Android/Fire TV devices through ADB",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "adb-mcp-server": "dist/index.js"
  },
  "scripts": {
