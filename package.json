  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "obs-websocket-js": "^5.0.8",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
